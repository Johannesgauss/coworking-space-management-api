{
  "info": {
    "name": "Projeto Reservas",
    "description": "",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{accessToken}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000", "type": "string" },
    { "key": "accessToken", "value": "", "type": "string" },
    { "key": "refreshToken", "value": "", "type": "string" },
    { "key": "verifyToken", "value": "", "type": "string" },
    { "key": "resetToken", "value": "", "type": "string" },
    { "key": "roomId", "value": "", "type": "string" },
    { "key": "reservationId", "value": "", "type": "string" },
    { "key": "userId", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John\",\n  \"lastName\": \"Doe\",\n  \"email\": \"john.doe@example.com\",\n  \"password\": \"SenhaForte123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "register"]
            },
            "description": "Cria uma nova conta. Um e-mail de verificação é enviado. Público."
          }
        },
        {
          "name": "Verify Email",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/auth/verify-email?token={{verifyToken}}",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "verify-email"],
              "query": [{ "key": "token", "value": "{{verifyToken}}" }]
            },
            "description": "Verifica/ativa a conta usando o token enviado por e-mail. Público."
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200 || pm.response.code === 201) {",
                  "  const json = pm.response.json();",
                  "  if (json.accessToken) {",
                  "    pm.collectionVariables.set('accessToken', json.accessToken);",
                  "    console.log('accessToken salvo');",
                  "  }",
                  "  if (json.refreshToken) {",
                  "    pm.collectionVariables.set('refreshToken', json.refreshToken);",
                  "    console.log('refreshToken salvo');",
                  "  }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john.doe@example.com\",\n  \"password\": \"SenhaForte123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            },
            "description": "Autentica e retorna `accessToken` e `refreshToken` (salvos automaticamente nas variáveis da coleção). Público."
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/auth/logout",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "logout"]
            },
            "description": "Encerra a sessão do usuário autenticado. Requer Bearer token."
          }
        },
        {
          "name": "Forgot Password",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john.doe@example.com\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/forgot-password",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "forgot-password"]
            },
            "description": "Envia um e-mail com token para redefinição de senha. Público."
          }
        },
        {
          "name": "Reset Password",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"password\": \"NovaSenha123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/reset-password?token={{resetToken}}",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "reset-password"],
              "query": [{ "key": "token", "value": "{{resetToken}}" }]
            },
            "description": "Redefine a senha usando o token recebido por e-mail. Público."
          }
        },
        {
          "name": "Change Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"password\": \"OutraSenha123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/change-password",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "change-password"]
            },
            "description": "Altera a senha do usuário autenticado. Requer Bearer token."
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Get Me",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/users/me",
              "host": ["{{baseUrl}}"],
              "path": ["users", "me"]
            },
            "description": "Retorna os dados do usuário autenticado. Requer Bearer token."
          }
        },
        {
          "name": "Update Me",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John\",\n  \"lastName\": \"Smith\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/users/me",
              "host": ["{{baseUrl}}"],
              "path": ["users", "me"]
            },
            "description": "Atualiza nome/sobrenome do usuário autenticado. Requer Bearer token."
          }
        }
      ]
    },
    {
      "name": "Rooms",
      "item": [
        {
          "name": "Create Room (ADMIN)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200 || pm.response.code === 201) {",
                  "  const json = pm.response.json();",
                  "  if (json.id) {",
                  "    pm.collectionVariables.set('roomId', json.id);",
                  "    console.log('roomId salvo: ' + json.id);",
                  "  }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Sala de Reunião A\",\n  \"capacity\": 8,\n  \"description\": \"Sala com projetor e ar-condicionado\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/rooms",
              "host": ["{{baseUrl}}"],
              "path": ["rooms"]
            },
            "description": "Cria uma sala. Requer role ADMIN. O `id` retornado é salvo em `roomId`."
          }
        },
        {
          "name": "Find All Rooms",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/rooms",
              "host": ["{{baseUrl}}"],
              "path": ["rooms"]
            },
            "description": "Lista todas as salas. Público."
          }
        },
        {
          "name": "Find Available Rooms",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/rooms/available?date=2026-07-15&startTime=2026-07-15T09:00:00Z&endTime=2026-07-15T11:00:00Z",
              "host": ["{{baseUrl}}"],
              "path": ["rooms", "available"],
              "query": [
                { "key": "date", "value": "2026-07-15" },
                { "key": "startTime", "value": "2026-07-15T09:00:00Z" },
                { "key": "endTime", "value": "2026-07-15T11:00:00Z" }
              ]
            },
            "description": "Lista salas disponíveis em um intervalo de tempo."
          }
        },
        {
          "name": "Find One Room",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/rooms/{{roomId}}",
              "host": ["{{baseUrl}}"],
              "path": ["rooms", "{{roomId}}"]
            },
            "description": "Retorna uma sala pelo ID. Público."
          }
        },
        {
          "name": "Update Room (ADMIN)",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Sala de Reunião A - Atualizada\",\n  \"capacity\": 10,\n  \"description\": \"Sala ampliada com TV e videoconferência\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/rooms/{{roomId}}",
              "host": ["{{baseUrl}}"],
              "path": ["rooms", "{{roomId}}"]
            },
            "description": "Atualiza uma sala. Requer role ADMIN."
          }
        },
        {
          "name": "Change Room Status (ADMIN)",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"isActive\": false\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/rooms/{{roomId}}/status",
              "host": ["{{baseUrl}}"],
              "path": ["rooms", "{{roomId}}", "status"]
            },
            "description": "Ativa/desativa uma sala. Requer role ADMIN."
          }
        },
        {
          "name": "Delete Room (ADMIN)",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/rooms/{{roomId}}",
              "host": ["{{baseUrl}}"],
              "path": ["rooms", "{{roomId}}"]
            },
            "description": "Remove uma sala. Requer role ADMIN."
          }
        }
      ]
    },
    {
      "name": "Reservations",
      "item": [
        {
          "name": "Find All User Reservations",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/reservations",
              "host": ["{{baseUrl}}"],
              "path": ["reservations"]
            },
            "description": "Lista as reservas do usuário autenticado. Requer Bearer token."
          }
        },
        {
          "name": "Create Reservation",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200 || pm.response.code === 201) {",
                  "  const json = pm.response.json();",
                  "  if (json.id) {",
                  "    pm.collectionVariables.set('reservationId', json.id);",
                  "    console.log('reservationId salvo: ' + json.id);",
                  "  }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"roomId\": \"{{roomId}}\",\n  \"date\": \"2026-07-15\",\n  \"startTime\": \"2026-07-15T09:00:00Z\",\n  \"endTime\": \"2026-07-15T11:00:00Z\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/reservations",
              "host": ["{{baseUrl}}"],
              "path": ["reservations"]
            },
            "description": "Cria uma reserva. Requer Bearer token. O `id` retornado é salvo em `reservationId`."
          }
        },
        {
          "name": "Reservation History",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/reservations/history",
              "host": ["{{baseUrl}}"],
              "path": ["reservations", "history"]
            },
            "description": "Histórico de reservas do usuário autenticado. Requer Bearer token."
          }
        },
        {
          "name": "Find One Reservation",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/reservations/{{reservationId}}",
              "host": ["{{baseUrl}}"],
              "path": ["reservations", "{{reservationId}}"]
            },
            "description": "Retorna uma reserva do usuário pelo ID. Requer Bearer token."
          }
        },
        {
          "name": "Cancel Reservation",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/reservations/{{reservationId}}",
              "host": ["{{baseUrl}}"],
              "path": ["reservations", "{{reservationId}}"]
            },
            "description": "Cancela uma reserva do usuário. Requer Bearer token."
          }
        }
      ]
    },
    {
      "name": "Admin Reservations",
      "item": [
        {
          "name": "Find All Reservations (ADMIN)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/admin/reservations",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "reservations"]
            },
            "description": "Lista todas as reservas do sistema. Requer role ADMIN."
          }
        },
        {
          "name": "Delete Reservation (ADMIN)",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/admin/reservations/{{reservationId}}",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "reservations", "{{reservationId}}"]
            },
            "description": "Remove qualquer reserva pelo ID. Requer role ADMIN."
          }
        }
      ]
    },
    {
      "name": "Admin Users",
      "item": [
        {
          "name": "Promote User to Admin (ADMIN)",
          "request": {
            "method": "PATCH",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/admin/users/{{userId}}",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "users", "{{userId}}"]
            },
            "description": "Promove um usuário comum para administrador usando seu ID. Requer role ADMIN."
          }
        }
      ]
    }
  ]
}
